<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title>Área Profesional · Abuela Tata</title>
  <link rel="icon" href="./assets/favicon.png">

  <style>
    :root{
      --bg:#f5efe6;
      --card:#fffaf4;
      --ink:#5b3f2d;
      --muted:#8b6f5b;
      --line:#e7d9cc;
      --accent:#2f7f75;
      --shadow:0 12px 30px rgba(0,0,0,.08);
      --radius:22px;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      font-family: ui-serif, Georgia, "Times New Roman", serif;
      background:var(--bg);
      color:var(--ink);
      min-height:100vh;
      background-image: radial-gradient(#e8dfd3 1px, transparent 1px);
      background-size:18px 18px;
    }

    .screen{
      min-height:100vh;
      width:100%;
    }

    /* SPLASH */
    .splash{
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
      background:var(--bg);
    }

    .splash-card{
      width:min(92vw, 520px);
      border-radius:28px;
      overflow:hidden;
      background:#fff;
      box-shadow:0 22px 50px rgba(0,0,0,.14);
      border:1px solid rgba(255,255,255,.7);
      transform:translateY(0);
      animation:fadeInUp .7s ease;
    }

    .splash-card img{
      display:block;
      width:100%;
      height:auto;
      object-fit:cover;
    }

    .splash-footer{
      padding:14px 16px 16px;
      text-align:center;
      font-size:14px;
      color:var(--muted);
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background:#fffaf7;
    }

    /* MENU */
    .menu-page{
      display:none;
      padding:18px 14px 26px;
      max-width:980px;
      margin:0 auto;
    }

    .top{
      text-align:center;
      padding:8px 0 18px;
    }

    .logo{
      width:min(220px, 58vw);
      height:auto;
      display:block;
      margin:0 auto 10px;
    }

    h1{
      margin:0;
      font-size:30px;
      letter-spacing:.2px;
    }

    .sub{
      margin-top:8px;
      color:var(--muted);
      font-size:14px;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      line-height:1.35;
    }

    .menu-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:14px;
      margin-top:14px;
    }

    .card{
      display:block;
      text-decoration:none;
      color:var(--ink);
      background:rgba(255,255,255,.78);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:18px 16px;
      transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;
      min-height:128px;
    }

    .card:hover{
      transform:translateY(-2px);
      box-shadow:0 16px 34px rgba(0,0,0,.10);
      border-color:#d8c8ba;
    }

    .icon{
      font-size:28px;
      line-height:1;
      margin-bottom:10px;
    }

    .title{
      font-size:19px;
      font-weight:700;
      margin-bottom:6px;
    }

    .desc{
      font-size:13px;
      line-height:1.4;
      color:var(--muted);
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    .foot-note{
      margin-top:16px;
      text-align:center;
      color:var(--muted);
      font-size:12px;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    @keyframes fadeInUp{
      from{
        opacity:0;
        transform:translateY(18px);
      }
      to{
        opacity:1;
        transform:translateY(0);
      }
    }

    @media (max-width:720px){
      .menu-page{
        padding:14px 10px 22px;
      }

      h1{
        font-size:24px;
      }

      .sub{
        font-size:13px;
      }

      .menu-grid{
        grid-template-columns:1fr;
        gap:12px;
      }

      .card{
        min-height:auto;
        padding:16px 14px;
      }

      .title{
        font-size:18px;
      }

      .icon{
        font-size:25px;
        margin-bottom:8px;
      }
    }
  </style>
</head>
<body>

  <!-- PANTALLA INICIAL BONITA -->
  <section class="screen splash" id="splashScreen">
    <div class="splash-card">
      <img src="./images/portada-area.jpg" alt="Área Profesional Abuela Tata">
      <div class="splash-footer">Área Profesional · Abuela Tata</div>
    </div>
  </section>

  <!-- MENÚ PRINCIPAL -->
  <main class="screen menu-page" id="menuPage">
    <div class="top">
      <img class="logo" src="./assets/logo.png" alt="Abuela Tata">
      <h1>Área Profesional</h1>
      <div class="sub">
        Acceso a herramientas, descargas y documentación de campaña.
      </div>
    </div>

    <div class="menu-grid">
      <a class="card" href="pedidos.html?modo=repeticiones">
        <div class="icon">📦</div>
        <div class="title">App de Repeticiones</div>
        <div class="desc">Realiza pedidos de repetición de Ceremonia 26.</div>
      </a>

      <a class="card" href="pedidos.html?modo=stock">
        <div class="icon">🧺</div>
        <div class="title">Stock disponible</div>
        <div class="desc">Consulta y pide el stock real disponible.</div>
      </a>

      <a class="card" href="multimedia.html">
        <div class="icon">📸</div>
        <div class="title">Descarga multimedia</div>
        <div class="desc">Acceso a imágenes y material visual en alta calidad.</div>
      </a>

      <a class="card" href="tarifa.html">
        <div class="icon">📄</div>
        <div class="title">Tarifa de precios</div>
        <div class="desc">Consulta la tarifa actual de la colección.</div>
      </a>

      <a class="card" href="calendario.html">
        <div class="icon">📅</div>
        <div class="title">Calendario de repeticiones</div>
        <div class="desc">Fechas de cierre y servicio previstas.</div>
      </a>

      <a class="card" href="condiciones.html">
        <div class="icon">ℹ️</div>
        <div class="title">Condiciones de campaña</div>
        <div class="desc">Información general y condiciones comerciales.</div>
      </a>
    </div>

    <div class="foot-note">
      Abuela Tata · Ceremonia 26
    </div>
  </main>

  <script>
    const splash = document.getElementById("splashScreen");
    const menu = document.getElementById("menuPage");

    function showMenu(){
      splash.style.display = "none";
      menu.style.display = "block";
      window.scrollTo(0,0);
    }

    // Si entra con ?menu=1, muestra el menú directo
    const params = new URLSearchParams(window.location.search);
    if(params.get("menu") === "1"){
      showMenu();
    } else {
      // Muestra splash y luego cambia a menú
      setTimeout(() => {
        history.replaceState({}, "", "index.html?menu=1");
        showMenu();
      }, 1800);
    }
  </script>

</body>
</html>
